# UDP Proxy listen address
PROXY_ADDR=0.0.0.0:19132

# Redis connection
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis key that the system writes the current best backend to
# Value format: "host:port"  e.g. "10.0.0.5:1234"
REDIS_BACKEND_KEY=udp_gate:backend

# Redis pub/sub channel the system publishes disconnect events on
# Message format: "clientIP:port"
REDIS_DISCONNECT_CHANNEL=udp_gate:disconnect

# Idle session timeout in seconds (safety-net cleanup)
SESSION_IDLE_TIMEOUT_SECS=60

# Worker pool size (default: GOMAXPROCS*2)
# WORKER_COUNT=8

# Inbound packet queue depth before drops occur
# QUEUE_SIZE=4096
